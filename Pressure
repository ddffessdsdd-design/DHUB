task.spawn(function()
    -- Wait for game to load
    local Rooms = nil
    for _ = 1, 40 do
        if workspace:FindFirstChild("GameplayFolder") and workspace.GameplayFolder:FindFirstChild("Rooms") then
            Rooms = workspace.GameplayFolder.Rooms
            break
        end
        task.wait(0.5)
    end
    if not Rooms then
        Rayfield:Notify({ Title = "Error", Content = "Game didn't load. Features disabled.", Duration = 5 })
        return
    end

    local Players = game:GetService("Players")
    local Player = Players.LocalPlayer
    local RunService = game:GetService("RunService")
    local ReplicatedStorage = game:GetService("ReplicatedStorage")
    local Workspace = game:GetService("Workspace")
    local Lighting = game:GetService("Lighting")

    local function GetRootPart()
        local char = Player.Character
        return char and char:FindFirstChild("HumanoidRootPart")
    end
    local function GetHumanoid()
        local char = Player.Character
        return char and char:FindFirstChildOfClass("Humanoid")
    end

    local lastNotify = {}
    local function NotifyOnce(key, title, content, duration)
        if lastNotify[key] and (tick() - lastNotify[key]) < 8 then return end
        lastNotify[key] = tick()
        Rayfield:Notify({ Title = title, Content = content, Duration = duration })
    end

    -- Helper functions for ESP
    local function AddESP(part, config)
        if not part or not part.Parent then return end
        if part:FindFirstChildOfClass("Highlight") then return end
        local h = Instance.new("Highlight")
        h.Adornee = part
        h.FillColor = config.fill
        h.OutlineColor = config.outline or WHITE
        h.FillTransparency = config.fillTransparency or 0.4
        h.OutlineTransparency = 0
        h.Parent = part
        local bb = Instance.new("BillboardGui")
        bb.Name = "ESP_Label"
        bb.Adornee = part
        bb.AlwaysOnTop = true
        bb.Size = UDim2.new(0, 140, 0, 40)
        bb.StudsOffset = Vector3.new(0, 3, 0)
        bb.Parent = part
        local lbl = Instance.new("TextLabel")
        lbl.Text = config.label
        lbl.Size = UDim2.new(1,0,1,0)
        lbl.BackgroundTransparency = 1
        lbl.TextColor3 = config.textColor or WHITE
        lbl.TextStrokeColor3 = Color3.fromRGB(0,0,0)
        lbl.TextStrokeTransparency = 0.3
        lbl.TextScaled = true
        lbl.Font = Enum.Font.GothamBold
        lbl.Parent = bb
        local stroke = Instance.new("UIStroke")
        stroke.Color = config.outline or WHITE
        stroke.Thickness = 1.5
        stroke.Parent = lbl
    end
    local function RemoveESP(part)
        if not part then return end
        local h = part:FindFirstChildOfClass("Highlight")
        if h then h:Destroy() end
        local b = part:FindFirstChild("ESP_Label")
        if b then b:Destroy() end
    end

    -- Scan rooms for items (for ESP toggles)
    local function ScanRooms(enabled, matchFn, onFound)
        local connections = {}
        local scanned = {}
        local function processDesc(d)
            if scanned[d] then return end
            scanned[d] = true
            if not d.Parent then return end
            local config = matchFn(d.Name)
            if config then
                local target = d:FindFirstChild("ProxyPart") or d
                onFound(target, config)
            end
        end
        local function scanRoom(room)
            for _, d in ipairs(room:GetDescendants()) do
                if not enabled() then break end
                processDesc(d)
            end
        end
        for _, room in ipairs(Rooms:GetChildren()) do
            if not enabled() then break end
            task.defer(function() scanRoom(room) end)
            table.insert(connections, room.DescendantAdded:Connect(function(d)
                task.wait(0.1)
                if enabled() then processDesc(d) end
            end))
        end
        table.insert(connections, Rooms.ChildAdded:Connect(function(room)
            task.wait(0.3)
            if not enabled() then return end
            scanRoom(room)
            table.insert(connections, room.DescendantAdded:Connect(function(d)
                task.wait(0.1)
                if enabled() then processDesc(d) end
            end))
        end))
        return connections
    end

    -- We'll store active ESP connections
    local espConnections = {}
    local espTargets = {}

    -- Function to start/stop ESP based on flag
    local function manageESP(flag, matchFn, cfgExtra)
        if Rayfield:GetFlag(flag) then
            if not espConnections[flag] then
                espConnections[flag] = ScanRooms(
                    function() return Rayfield:GetFlag(flag) end,
                    matchFn,
                    function(target, config)
                        if cfgExtra then
                            for k,v in pairs(cfgExtra) do config[k] = v end
                        end
                        AddESP(target, config)
                        if not espTargets[flag] then espTargets[flag] = {} end
                        table.insert(espTargets[flag], target)
                    end
                )
            end
        else
            if espConnections[flag] then
                for _, c in ipairs(espConnections[flag]) do c:Disconnect() end
                espConnections[flag] = nil
            end
            if espTargets[flag] then
                for _, target in ipairs(espTargets[flag]) do
                    pcall(RemoveESP, target)
                end
                espTargets[flag] = nil
            end
        end
    end

    -- Helper for anti toggles (remove objects)
    local function manageAnti(flag, matchFn)
        if Rayfield:GetFlag(flag) then
            -- Remove existing ones
            for _, obj in pairs(Workspace:GetDescendants()) do
                if matchFn(obj.Name) then
                    pcall(obj.Destroy, obj)
                end
            end
            -- Listen for new ones
            if not _G[flag.."_conn"] then
                _G[flag.."_conn"] = Rooms.ChildAdded:Connect(function(room)
                    task.wait(0.3)
                    if not Rayfield:GetFlag(flag) then return end
                    local function removeInRoom(rm)
                        for _, d in ipairs(rm:GetDescendants()) do
                            if matchFn(d.Name) then pcall(d.Destroy, d) end
                        end
                    end
                    removeInRoom(room)
                    local descConn = room.DescendantAdded:Connect(function(d)
                        if Rayfield:GetFlag(flag) and matchFn(d.Name) then pcall(d.Destroy, d) end
                    end)
                    _G[flag.."_desc"] = descConn
                end)
            end
        else
            if _G[flag.."_conn"] then _G[flag.."_conn"]:Disconnect(); _G[flag.."_conn"] = nil end
            if _G[flag.."_desc"] then _G[flag.."_desc"]:Disconnect(); _G[flag.."_desc"] = nil end
        end
    end

    -- Main feature loop (some features run on heartbeat, some periodic)
    -- ESP toggles will be managed by the functions above; we'll call them in a loop.
    task.spawn(function()
        while true do
            task.wait(0.5) -- check ESP toggles every 0.5s
            manageESP("EspKeycard", function(n) return KEYCARDS[n] end)
            manageESP("EspCurrency", function(n) return GetCurrencyConfig(n) end)
