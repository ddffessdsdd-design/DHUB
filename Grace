-- ========================== GRACE AUTOPLAY (FIXED VOID ISSUE) ==========================
local isGrace = game.PlaceId == 110333320616502
local graceFeatures = {}

if isGrace then
    print("[Grace] Autoplay loaded")
    local Rooms = workspace:WaitForChild("Rooms")
    
    local settings = {
        Running = false,
        CanStart = false,
        ActionCooldown = 0.7,
        DoorDelay = 0.5,
        ProcessedRooms = {},
        CurrentRoom = 0,
        LastRoomLabel = nil,
        AutoPlayToggle = nil,
    }
    
    local function getRoomNumber(room)
        return tonumber(room.Name)
    end
    
    local function getLatestRoomNumber()
        local highest = 0
        for _, room in Rooms:GetChildren() do
            local num = getRoomNumber(room)
            if num and num > highest then highest = num end
        end
        return highest
    end
    
    local function teleportToCFrame(cf)
        local char = player.Character
        if char and char:FindFirstChild("HumanoidRootPart") then
            char.HumanoidRootPart.CFrame = cf
            return true
        end
        return false
    end
    
    -- Helper to find a valid teleport target inside a room (Entrance or any BasePart)
    local function getRoomTeleportTarget(room)
        local entrance = room:FindFirstChild("Entrance")
        if entrance and entrance:IsA("BasePart") then
            return entrance.CFrame
        end
        -- fallback: any part inside the room (avoid void)
        for _, child in ipairs(room:GetDescendants()) do
            if child:IsA("BasePart") and child.Name ~= "Hitbox" then
                return child.CFrame
            end
        end
        return nil
    end
    
    local function processRoom(room, roomNumber)
        if settings.ProcessedRooms[roomNumber] then return false end
        
        local targetCFrame = getRoomTeleportTarget(room)
        if not targetCFrame then
            warn("No valid teleport target in room", roomNumber)
            return false
        end
        
        teleportToCFrame(targetCFrame)
        task.wait(settings.DoorDelay)
        
        -- Safe room Scale handling (unchanged)
        local safeRoomModel = room:FindFirstChild("SafeRoom")
        local scaleModel = safeRoomModel and safeRoomModel:FindFirstChild("Scale")
        if scaleModel and scaleModel:IsA("Model") then
            local hitbox = scaleModel:FindFirstChild("Hitbox") or scaleModel:FindFirstChildWhichIsA("BasePart")
            if hitbox then
                local function checkAttribute()
                    local inRoom = player:GetAttribute("InRoom") or player:GetAttribute("ClientInRoom")
                    return inRoom and tonumber(inRoom) == roomNumber
                end
                local startTime = tick()
                while tick() - startTime < 10 do
                    if checkAttribute() then
                        teleportToCFrame(hitbox.CFrame)
                        task.wait(1.5)
                        settings.ProcessedRooms[roomNumber] = true
                        return true
                    end
                    task.wait(0.1)
                end
                settings.ProcessedRooms[roomNumber] = true
                return true
            end
        end
        
        -- Normal room: expand plug/beacon hitboxes
        local vault = room:FindFirstChild("VaultEntrance")
        local prompt = vault and vault:FindFirstChild("Hinged") and vault.Hinged:FindFirstChild("Cylinder") and vault.Hinged.Cylinder:FindFirstChild("ProximityPrompt")
        if prompt then
            local trigger = ReplicatedStorage:FindFirstChild("TriggerPrompt")
            if trigger then trigger:FireServer(prompt) end
            teleportToCFrame(vault:GetPivot())
            task.wait(settings.ActionCooldown)
        end
        
        local plug = room:FindFirstChild("Plug")
        local plugTouch = plug and plug:FindFirstChild("plugTouch")
        if plugTouch then
            plugTouch.Size = Vector3.new(2048,2048,2048)
            plugTouch.CFrame = (player.Character and player.Character:GetPivot()) or plugTouch.CFrame
            task.wait(settings.ActionCooldown)
        end
        
        local beacon = room:FindFirstChild("Beacon")
        local beaconHitbox = beacon and beacon:FindFirstChild("Hitbox")
        if beaconHitbox then
            beaconHitbox.Size = Vector3.new(2048,2048,2048)
            beaconHitbox.CFrame = (player.Character and player.Character:GetPivot()) or beaconHitbox.CFrame
            task.wait(settings.ActionCooldown)
        end
        
        settings.ProcessedRooms[roomNumber] = true
        return true
    end
    
    local function autoplayLoop()
        while settings.Running and settings.CanStart do
            local latestRoomNumber = getLatestRoomNumber()
            if latestRoomNumber > settings.CurrentRoom then
                settings.CurrentRoom = latestRoomNumber
                if settings.LastRoomLabel then
                    settings.LastRoomLabel:Set("Last Room: " .. latestRoomNumber)
                end
            end
            
            -- Find the highest unprocessed room
            local targetRoom = nil
            local targetNumber = 0
            for _, room in Rooms:GetChildren() do
                local num = getRoomNumber(room)
                if num and not settings.ProcessedRooms[num] and num > targetNumber then
                    targetNumber = num
                    targetRoom = room
                end
            end
            
            if targetRoom then
                processRoom(targetRoom, targetNumber)
                task.wait(settings.ActionCooldown)
            else
                task.wait(0.5)
            end
        end
    end
    
    local autoplayThread = nil
    local function setAutoplay(enabled)
        settings.Running = enabled
        if enabled and settings.CanStart then
            if autoplayThread then task.cancel(autoplayThread) end
            autoplayThread = task.spawn(autoplayLoop)
        elseif not enabled and autoplayThread then
            task.cancel(autoplayThread)
            autoplayThread = nil
        end
    end
    
    local function checkFirstSafeRoom()
        local highest = getLatestRoomNumber()
        if highest >= 24 then
            settings.CanStart = true
            return true
        else
            settings.CanStart = false
            Rayfield:Notify({Title = "Grace", Content = "Please reach room 24 or higher first", Duration = 4})
            local conn
            conn = Rooms.ChildAdded:Connect(function()
                if getLatestRoomNumber() >= 24 then
                    settings.CanStart = true
                    conn:Disconnect()
                    Rayfield:Notify({Title = "Grace", Content = "Autoplay now available", Duration = 3})
                    if settings.Running then setAutoplay(true) end
                end
            end)
            return false
        end
    end
    checkFirstSafeRoom()
    
    graceFeatures = {
        toggle = setAutoplay,
        getSettings = function() return settings end,
        teleportToLastRoom = function()
            local latest = getLatestRoomNumber()
            if latest == 0 then return end
            for _, room in Rooms:GetChildren() do
                if getRoomNumber(room) == latest then
                    local targetCFrame = getRoomTeleportTarget(room)
                    if targetCFrame then
                        teleportToCFrame(targetCFrame)
                        Rayfield:Notify({Title = "Grace", Content = "Teleported to room " .. latest, Duration = 2})
                    else
                        Rayfield:Notify({Title = "Grace", Content = "No valid teleport point", Duration = 2})
                    end
                    break
                end
            end
        end,
        resetProcessed = function()
            settings.ProcessedRooms = {}
            settings.CurrentRoom = 0
            Rayfield:Notify({Title = "Grace", Content = "Reset processed rooms", Duration = 2})
        end
    }
end

