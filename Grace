-- ========================== ENTITY DELETER ==========================
local exactNames = { "Worm", "Rush", "Rain", "elkman", "GOATPORT", "Goatman" }
local partialMatches = { "goat" }

local function shouldDelete(inst)
    local name = inst.Name
    for _, n in ipairs(exactNames) do
        if name == n then return true end
    end
    local lower = name:lower()
    for _, p in ipairs(partialMatches) do
        if lower:find(p) then return true end
    end
    if name == "Part" and inst:FindFirstChild("rueflashparticle") then return true end
    if name == "Part" then
        local hands = inst:FindFirstChild("hands")
        if hands and hands:IsA("Folder") then return true end
    end
    return false
end

local scanServices = { Workspace, ReplicatedStorage }
local playerGui = player:FindFirstChild("PlayerGui")
if playerGui then table.insert(scanServices, playerGui) end

local deleteLoop = nil
local autoDeleteActive = false

local function deleteEntities()
    for _, svc in ipairs(scanServices) do
        if svc then
            for _, obj in ipairs(svc:GetDescendants()) do
                if shouldDelete(obj) then
                    pcall(function() obj:Destroy() end)
                end
            end
        end
    end
end

local function startDeleteLoop()
    if deleteLoop then return end
    deleteLoop = task.spawn(function()
        while autoDeleteActive do
            deleteEntities()
            task.wait(0.5)
        end
        deleteLoop = nil
    end)
end

local function stopDeleteLoop()
    autoDeleteActive = false
    if deleteLoop then
        task.cancel(deleteLoop)
        deleteLoop = nil
    end
end

local function debugScanEntities()
    local found = {}
    local allScan = { Workspace, ReplicatedStorage, playerGui }
    for _, svc in ipairs(allScan) do
        if svc then
            for _, obj in ipairs(svc:GetDescendants()) do
                local lower = obj.Name:lower()
                if lower:find("worm") or lower:find("rush") or lower:find("rain") or lower:find("elkman") or lower:find("goat") or lower:find("rue") or lower:find("mime") then
                    table.insert(found, obj:GetFullName() .. " (" .. obj.ClassName .. ")")
                end
            end
        end
    end
    if #found == 0 then
        Rayfield:Notify({Title = "Debug", Content = "No matching entities found", Duration = 3})
    else
        print("=== Entity Debug ===")
        for _, line in ipairs(found) do print(line) end
        Rayfield:Notify({Title = "Debug", Content = "Check F9 console for names", Duration = 3})
    end
end

