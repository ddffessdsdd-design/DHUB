-- ========================== SORROW DOMAIN TP ==========================
local sorrowActive = false
local sorrowThread = nil

local function getBeaconParts()
    local beacons = {}
    for _, folder in ipairs(Workspace:GetDescendants()) do
        if folder.Name == "Beacon" and folder:IsA("Folder") then
            local parent = folder.Parent
            if parent and parent:IsA("Model") and parent:FindFirstChild("BloodOcean") and parent.BloodOcean:IsA("Folder") then
                for _, part in ipairs(folder:GetDescendants()) do
                    if part:IsA("BasePart") then
                        table.insert(beacons, part)
                    end
                end
            end
        end
    end
    return beacons
end

local function teleportToPart(part)
    local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if hrp and part and part.Parent then
        hrp.CFrame = part.CFrame + Vector3.new(0,10,0)
        return true
    end
    return false
end

local function startSorrowLoop()
    if sorrowThread then return end
    sorrowThread = task.spawn(function()
        while sorrowActive do
            local parts = getBeaconParts()
            if #parts == 0 then
                Rayfield:Notify({Title = "Sorrow", Content = "No beacons with BloodOcean", Duration = 2})
                sorrowActive = false
                break
            end
            for _, part in ipairs(parts) do
                if not sorrowActive then break end
                teleportToPart(part)
                task.wait(0.5)
            end
            task.wait(0.5)
        end
        sorrowThread = nil
    end)
end

local function stopSorrowLoop()
    sorrowActive = false
    if sorrowThread then
        task.cancel(sorrowThread)
        sorrowThread = nil
    end
end

