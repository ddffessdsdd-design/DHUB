    -- Generator ESP (dynamic based on Fixed value)
    local function updateGeneratorESP()
        if not Rayfield:GetFlag("EspGenerator") then
            -- remove all generator ESP
            for _, room in ipairs(Rooms:GetChildren()) do
                for _, d in ipairs(room:GetDescendants()) do
                    if d.Name == "PresetGenerator" or d.Name == "Generator" then
                        RemoveESP(d:FindFirstChild("ProxyPart") or d)
                    end
                end
            end
            return
        end
        for _, room in ipairs(Rooms:GetChildren()) do
            for _, gen in ipairs(room:GetDescendants()) do
                if (gen.Name == "PresetGenerator" or gen.Name == "Generator") and gen:FindFirstChild("Fixed") then
                    local fixed = gen.Fixed
                    local pct = fixed.Value
                    if pct < 100 then
                        local r = math.floor(255 * (1 - pct/100))
                        local g = math.floor(255 * (pct/100))
                        local cfg = { label = "⚙ Generator " .. math.floor(pct) .. "%", fill = Color3.fromRGB(r,g,0), outline = Color3.fromRGB(255,200,0), textColor = WHITE, fillTransparency = 0.3 }
                        local proxy = gen:FindFirstChild("ProxyPart") or gen
                        AddESP(proxy, cfg)
                        -- listen for changes
                        if not gen._espConn then
                            gen._espConn = fixed:GetPropertyChangedSignal("Value"):Connect(function()
                                updateGeneratorESP()
                            end)
                        end
                    else
                        local proxy = gen:FindFirstChild("ProxyPart") or gen
                        RemoveESP(proxy)
                        if gen._espConn then gen._espConn:Disconnect(); gen._espConn = nil end
                    end
                end
            end
        end
    end
    task.spawn(function()
        while true do
            task.wait(1)
            updateGeneratorESP()
        end
    end)

