                                            end
                                        end
                                    end
                                    if not proxy then proxy = obj end
                                    local targetPos = proxy:IsA("BasePart") and proxy.Position or obj:GetPivot().Position
                                    local dir = (targetPos - root.Position).Unit
                                    root.CFrame = CFrame.new(targetPos - dir*4 + Vector3.new(0,3,0))
                                    task.wait(0.2)
                                    local code = FindPasswordForRoom(obj)
                                    if not code or #code==0 then
                                        solving[obj]=nil; return
                                    end
                                    local digitButtons = {}
                                    local submitPart = nil
                                    for _, part in ipairs(obj:GetDescendants()) do
                                        local pn = part.Name
                                        local prompt = part:FindFirstChildWhichIsA("ProximityPrompt") or part:FindFirstChildWhichIsA("ClickDetector")
                                        if prompt then
                                            if pn == "submit" or pn == "enter" or pn == "KeypadSubmit" or pn == "KeypadEnter" or string.lower(pn)=="submit" or string.lower(pn)=="enter" then
                                                submitPart = prompt
                                            elseif pn == "0" or pn == "Keypad0" or string.match(pn,"Button0$") then digitButtons["0"]=prompt
                                            elseif pn == "1" or pn == "Keypad1" or string.match(pn,"Button1$") then digitButtons["1"]=prompt
